<Window x:Class="WindowsDesktopInfoPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsDesktopInfoPanel" 
        Height="253" Width="380"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False">

    <Grid>
        <Border x:Name="MainBorder" CornerRadius="10" Background="#44000000" Margin="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtDate" FontSize="20" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" Text="Knödeltag 26.04.1986">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="TxtTime" FontSize="100" Foreground="White" Margin="0,-20,0,-15" HorizontalAlignment="Center" FontWeight="Bold" Text="17:17">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTemp" FontSize="50" Foreground="#FF00CCFF" Text="-- °C">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock FontSize="50" Foreground="White" Text=" | " />
                    <StackPanel Orientation="Vertical" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHum" FontSize="20" Foreground="#FF00FFCC" Text="-- %">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="TxtDew" FontSize="20" Foreground="#FF00FFCC" Text="-- °C">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>